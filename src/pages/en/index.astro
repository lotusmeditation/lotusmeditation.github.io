---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Welcome to Lotus Meditation</h1>
				<p class="lead">
					A non-profit club helping each of us become a better version of ourselves
					through <em>bien-être</em> and meditation. 100% free, community-driven, open to everyone.
				</p>
			</section>

			<section class="pillars">
				<article>
					<img src="/blog-placeholder-2.jpg" alt="" />
					<h2>🌱 Well-being</h2>
					<p>Simple practices to bring more calm, focus, and balance into everyday life.</p>
				</article>
				<article>
					<img src="/blog-placeholder-3.jpg" alt="" />
					<h2>🧘 Meditation</h2>
					<p>Guided sessions and gentle techniques accessible to beginners and regular practitioners alike.</p>
				</article>
				<article>
					<img src="/blog-placeholder-4.jpg" alt="" />
					<h2>🤝 Community</h2>
					<p>Run by volunteers, for everyone. No fees, no ads — just shared practice and growth.</p>
				</article>
			</section>

			<section class="cta">
				<h2>Stay tuned — the site is under construction 🚧</h2>
				<p>
					We're putting things together. Check back soon for articles, reflections,
					and practice notes from the community.
				</p>
			</section>
		</main>
		<Footer />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}
			.hero {
				text-align: center;
				margin-bottom: 4rem;
				padding-top: 2rem;
			}
			.hero h1 {
				font-size: 2.5rem;
				margin: 0 0 0.5rem;
			}
			.lead {
				font-size: 1.15rem;
				color: rgb(var(--gray-dark));
				max-width: 640px;
				margin: 0 auto;
			}
			.pillars {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 2rem;
				margin-bottom: 4rem;
			}
			.pillars article {
				text-align: center;
			}
			.pillars img {
				width: 100%;
				height: 160px;
				object-fit: cover;
				border-radius: 10px;
				margin-bottom: 1rem;
			}
			.pillars h2 {
				font-size: 1.25rem;
				margin: 0 0 0.5rem;
			}
			.pillars p {
				color: rgb(var(--gray));
				font-size: 0.95rem;
				margin: 0;
			}
			.cta {
				text-align: center;
				padding: 2rem 1rem;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.cta h2 {
				margin: 0 0 0.5rem;
			}
		</style>
	</body>
</html>
