---
import { getRelativeLocaleUrl } from 'astro:i18n';
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import lotusLogo from '../assets/icons8-flower-64.png';

const locale = Astro.currentLocale ?? 'en';
const homeUrl = getRelativeLocaleUrl(locale, '');
const aboutUrl = getRelativeLocaleUrl(locale, 'about');

const segments = Astro.url.pathname.split('/').filter(Boolean);
const subpath = segments.slice(1).join('/');

const languages = [
	{ code: 'en', label: 'English' },
	{ code: 'fr', label: 'Français' },
	{ code: 'vi', label: 'Tiếng Việt' },
];
const current = languages.find((l) => l.code === locale) ?? languages[0];
---

<header>
	<nav>
		<h2>
			<a href={homeUrl} class="brand">
				<img class="brand-logo" src={lotusLogo.src} width="32" height="32" alt="" aria-hidden="true" />
				<span class="brand-title">{SITE_TITLE}</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href={homeUrl}>Home</HeaderLink>
			<!-- Blog disabled until content is ready -->
			<!-- <HeaderLink href={getRelativeLocaleUrl(locale, 'blog')}>Blog</HeaderLink> -->
			<HeaderLink href={aboutUrl}>About</HeaderLink>
		</div>
		<div class="right-links">
			<div class="lang-menu">
				<button class="lang-trigger" type="button" aria-haspopup="menu" aria-expanded="false" aria-label="Choose language" title="Choose language">
					<svg class="globe" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="12" cy="12" r="10"></circle>
						<path d="M2 12h20"></path>
						<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
					</svg>
					<span class="current">{current.label}</span>
					<svg class="chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
						<path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</button>
				<ul class="lang-panel" role="menu">
					{languages.map((l) => (
						<li role="none">
							<a
								role="menuitem"
								href={getRelativeLocaleUrl(l.code, subpath)}
								hreflang={l.code}
								data-locale={l.code}
								aria-current={l.code === locale ? 'true' : undefined}
								class:list={['lang-item', { active: l.code === locale }]}
							>{l.label}</a>
						</li>
					))}
				</ul>
			</div>
		</div>
	</nav>
</header>

<script is:inline>
	document.querySelectorAll('a.lang-item[data-locale]').forEach((a) => {
		a.addEventListener('click', () => {
			try {
				localStorage.setItem('preferredLocale', a.getAttribute('data-locale'));
			} catch (e) {}
		});
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 3.5rem;
	}
	nav h2 {
		display: flex;
		align-items: center;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5em 0.25em;
	}
	.brand-logo {
		display: block;
		width: 32px;
		height: 32px;
		flex-shrink: 0;
	}
	.internal-links {
		display: flex;
		align-items: center;
	}
	.right-links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	nav a {
		display: inline-flex;
		align-items: center;
		padding: 1em 0.5em;
		color: var(--black);
		text-decoration: none;
		box-shadow: inset 0 -4px 0 transparent;
		transition: box-shadow 0.15s ease;
	}
	nav a.active {
		text-decoration: none;
		box-shadow: inset 0 -4px 0 var(--accent);
	}
	/* Language popdown */
	.lang-menu {
		position: relative;
	}
	.lang-trigger {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		cursor: pointer;
		height: 2.25rem;
		padding: 0 0.75rem;
		margin: 0;
		border: none;
		border-radius: 6px;
		font-size: 0.85rem;
		line-height: 1;
		font-family: inherit;
		color: rgb(var(--gray-dark));
		background: transparent;
		transition: color 0.15s ease, background-color 0.15s ease;
	}
	.lang-trigger > svg {
		display: block;
		flex-shrink: 0;
	}
	.lang-trigger > .current {
		display: inline-flex;
		align-items: center;
		line-height: 1;
	}
	.lang-menu:hover .lang-trigger,
	.lang-menu:focus-within .lang-trigger,
	.lang-trigger:hover {
		color: rgb(var(--black));
	}
	.lang-trigger .chevron {
		transition: transform 0.2s ease;
	}
	.lang-menu:hover .lang-trigger .chevron,
	.lang-menu:focus-within .lang-trigger .chevron {
		transform: rotate(180deg);
	}
	.lang-panel {
		position: absolute;
		top: 100%;
		right: 0;
		margin: 0;
		padding: 0.4rem 0;
		list-style: none;
		min-width: 12rem;
		background: white;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		box-shadow: 0 8px 24px rgba(var(--black), 10%);
		z-index: 20;
		opacity: 0;
		visibility: hidden;
		transform: translateY(-4px);
		transition: opacity 0.15s ease, transform 0.15s ease, visibility 0s linear 0.15s;
	}
	.lang-menu:hover .lang-panel,
	.lang-menu:focus-within .lang-panel {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
		transition: opacity 0.15s ease, transform 0.15s ease, visibility 0s;
	}
	.lang-panel li {
		margin: 0;
	}
	.lang-panel .lang-item {
		display: block;
		padding: 0.55rem 0.9rem;
		color: rgb(var(--gray-dark));
		font-size: 0.9rem;
		text-decoration: none;
		border-bottom: none;
		box-shadow: none;
	}
	.lang-panel .lang-item:hover {
		background: rgb(var(--gray-light));
		color: rgb(var(--black));
	}
	.lang-panel .lang-item.active {
		font-weight: 600;
		color: rgb(var(--black));
	}

	@media (max-width: 720px) {
		.lang-trigger {
			padding: 0 0.6rem;
		}
		.lang-trigger .current {
			display: none;
		}
		.brand-title {
			display: none;
		}
	}
</style>
